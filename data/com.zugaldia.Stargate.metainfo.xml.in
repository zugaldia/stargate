<component type="desktop-application">
    <id>com.zugaldia.Stargate</id>
    <name>Stargate</name>
    <summary>XDG Desktop Portals for the Linux desktop</summary>
    <metadata_license>MIT</metadata_license>
    <project_license>MIT</project_license>
    <description>
        <p>
            Stargate is a Kotlin JVM library and GTK4 GUI example application providing access
            to XDG Desktop Portals on Linux. It uses D-Bus for portal communication and Java-GI
            for GTK bindings.
        </p>
    </description>

    <url type="homepage">https://github.com/zugaldia/stargate</url>
    <url type="vcs-browser">https://github.com/zugaldia/stargate</url>
    <url type="bugtracker">https://github.com/zugaldia/stargate/issues</url>
    <url type="donation">https://github.com/sponsors/zugaldia</url>

    <url type="contact">https://www.zugaldia.com</url>
    <developer id="com.zugaldia">
        <name>Antonio Zugaldia</name>
    </developer>

    <content_rating type="oars-1.1" />
    <launchable type="desktop-id">com.zugaldia.Stargate.desktop</launchable>

    <releases>
        <release version="0.1.0" date="2026-03-18">
            <url type="details">https://github.com/zugaldia/stargate/releases/tag/v0.1.0</url>
            <description>
                <p>First release of Stargate.</p>
            </description>
        </release>
    </releases>
</component>
